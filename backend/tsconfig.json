{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "sourceMap": true,

    "types": ["node", "jest"]
  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}
